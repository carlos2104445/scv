{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(site)/layout,_N_T_/(site)/search/layout,_N_T_/(site)/search/page,_N_T_/search"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KHNpdGUp/search/__PAGE__",
    "/!KHNpdGUp/search",
    "/!KHNpdGUp",
    "/_index",
    "/_head"
  ]
}
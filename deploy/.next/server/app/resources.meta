{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(site)/layout,_N_T_/(site)/resources/layout,_N_T_/(site)/resources/page,_N_T_/resources"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KHNpdGUp/resources/__PAGE__",
    "/!KHNpdGUp/resources",
    "/!KHNpdGUp",
    "/_index",
    "/_head"
  ]
}
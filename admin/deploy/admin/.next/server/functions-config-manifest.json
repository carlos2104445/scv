{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!login|api\\/auth|api\\/v1|api\\/uploads|_next|favicon.ico|images).*))(\\.json)?[\\/#\\?]?$",
          "originalSource": "/((?!login|api/auth|api/v1|api/uploads|_next|favicon.ico|images).*)"
        }
      ]
    }
  }
}